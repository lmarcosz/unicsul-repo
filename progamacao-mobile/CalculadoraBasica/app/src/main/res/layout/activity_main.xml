<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_marginHorizontal="10dp"
    tools:ignore="ExtraText">
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#2196F3"
        android:textSize="30sp"
        android:text="Calculadora Básica" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Primeiro Número" />

    <EditText
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/editNumero1"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Segundo Número" />

    <EditText
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/editNumero2"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <Button
            android:layout_width="120sp"
            android:layout_height="120sp"
            app:cornerRadius="5dp"
            android:layout_marginHorizontal="10dp"
            android:backgroundTint="#30AD06"
            android:textColor="#000000"
            android:textSize="50sp"
            android:text ="+"
            android:onClick="somar"/>

        <Button
            android:layout_width="120sp"
            android:layout_height="120sp"
            app:cornerRadius="5dp"
            android:layout_marginHorizontal="10dp"
            android:backgroundTint="#EF139B"
            android:textColor="#ffffff"
            android:textSize="50sp"
            android:text ="-"
            android:onClick="subtrair"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp">
        <Button
            android:layout_width="120sp"
            android:layout_height="120sp"
            app:cornerRadius="5dp"
            android:layout_marginHorizontal="10dp"
            android:backgroundTint="#FFC107"
            android:textColor="#000000"
            android:textSize="50sp"
            android:text ="*"
            android:onClick="multiplicar"/>

        <Button
            android:layout_width="120sp"
            android:layout_height="120sp"
            app:cornerRadius="5dp"
            android:layout_marginHorizontal="10dp"
            android:backgroundTint="#263BE7"
            android:textColor="#ffffff"
            android:textSize="50sp"
            android:text ="/"
            android:onClick="dividir"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="50dp"
        android:textSize="50sp"
        android:textColor="#00BCD4"
        android:id="@+id/showResultado" />

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eggshell"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        tools:context=".MainActivity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:text="@string/tituloCalculadora_PT" />

            <ImageView
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_marginHorizontal="30dp"
                android:layout_marginVertical="10dp"
                android:src="@drawable/calculadora2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:justificationMode="inter_word"
                android:layout_marginHorizontal="15dp"
                android:layout_marginVertical="15dp"
                android:textColor="@color/grey"
                android:text="@string/txCalculadora_PT" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/cherry"
            android:textSize="30sp"
            android:textStyle="bold"
            android:text="@string/tituloCalculadoraBasica_PT" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:textColor="@color/black"
            android:hint="Primeiro Número"
            android:id="@+id/editNumero1"/>

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:textColor="@color/black"
            android:hint="Segundo Número"
            android:id="@+id/editNumero2"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <Button
                android:layout_width="120sp"
                android:layout_height="120sp"
                app:cornerRadius="5dp"
                android:layout_marginHorizontal="10dp"
                android:backgroundTint="#30AD06"
                android:textColor="#000000"
                android:textSize="50sp"
                android:text ="+"
                android:onClick="somar"/>

            <Button
                android:layout_width="120sp"
                android:layout_height="120sp"
                app:cornerRadius="5dp"
                android:layout_marginHorizontal="10dp"
                android:backgroundTint="#EF139B"
                android:textColor="#ffffff"
                android:textSize="50sp"
                android:text ="-"
                android:onClick="subtrair"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">
            <Button
                android:layout_width="120sp"
                android:layout_height="120sp"
                app:cornerRadius="5dp"
                android:layout_marginHorizontal="10dp"
                android:backgroundTint="#FFC107"
                android:textColor="#000000"
                android:textSize="50sp"
                android:text ="*"
                android:onClick="multiplicar"/>

            <Button
                android:layout_width="120sp"
                android:layout_height="120sp"
                app:cornerRadius="5dp"
                android:layout_marginHorizontal="10dp"
                android:backgroundTint="#263BE7"
                android:textColor="#ffffff"
                android:textSize="50sp"
                android:text ="/"
                android:onClick="dividir"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="50dp"
            android:textSize="50sp"
            android:textColor="@color/cherry"
            android:text="0"
            android:layout_marginHorizontal="10dp"
            android:layout_marginVertical="40dp"
            android:id="@+id/showResultado" />

    </LinearLayout>

</ScrollView>